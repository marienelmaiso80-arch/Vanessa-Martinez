      <!-- Item 3 : Mesa Coffee Table -->
      <div class="item-card">
        <div class="item-image" style="background: #DDD0BC;">🗻 ⟷ 🪵</div>
        <div class="item-info">
          <h3>Mesa Coffee Table</h3>
          <div class="item-material">white oak · sculpted base</div>
          <div class="item-description">Organic silhouette, lower shelf for storage. Minimalist yet warm.</div>
          <div class="item-feature"><span class="badge">✧ hand-carved</span><span class="badge">📚 hidden storage</span></div>
        </div>
      </div>
      
      <!-- Item 4 : Arch Bookshelf -->
      <div class="item-card">
        <div class="item-image" style="background: #DACEB9;">📚 🪵</div>
        <div class="item-info">
          <h3>Archway Bookshelf</h3>
          <div class="item-material">black walnut & steel</div>
          <div class="item-description">Curved top, 5 adjustable shelves. Architectural statement for any room.</div>
          <div class="item-feature"><span class="badge">✧ heirloom joinery</span><span class="badge">⚙️ adjustable</span></div>
        </div>
      </div>
      
      <!-- Item 5 : Spindle Bed Frame -->
      <div class="item-card">
        <div class="item-image" style="background: #E3D5C2;">🛏️ ⟷ 🌾</div>
        <div class="item-info">
          <h3>Spindle Bed Frame (Queen/King)</h3>
          <div class="item-material">solid ash + hand-turned spindles</div>
          <div class="item-description">Inspired by Shaker design, slatted headboard, no box spring needed.</div>
          <div class="item-feature"><span class="badge">✧ zero creak</span><span class="badge">🌲 FSC certified</span></div>
        </div>
      </div>
      
      <!-- Item 6 : Oak Media Console -->
      <div class="item-card">
        <div class="item-image" style="background: #E2D3BD;">📺 🪵</div>
        <div class="item-info">
          <h3>Mid-Century Media Console</h3>
          <div class="item-material">american oak · hairpin legs</div>
          <div class="item-description">Sliding doors, cable management, spacious compartments.</div>
          <div class="item-feature"><span class="badge">✧ soft-close</span><span class="badge">♻️ recycled steel legs</span></div>
        </div>
      </div>
      
      <!-- Item 7 : Round Pedestal Table -->
      <div class="item-card">
        <div class="item-image" style="background: #DDCDB5;">🍽️ ⟷ 🌀</div>
        <div class="item-info">
          <h3>Gather Round Table</h3>
          <div class="item-material">curly maple + cast iron base</div>
          <div class="item-description">48" diameter, expands to 62". Perfect for gatherings.</div>
          <div class="item-feature"><span class="badge">✧ butterfly leaf</span><span class="badge">🔨 artisan-made</span></div>
        </div>
      </div>
      
      <!-- Item 8 : Woven Bench -->
      <div class="item-card">
        <div class="item-image" style="background: #EDE0CF;">🪑 ➰</div>
        <div class="item-info">
          <h3>Woven Rattan Bench</h3>
          <div class="item-material">solid teak + handwoven rattan</div>
          <div class="item-description">Organic texture, ideal for entryway or foot of bed. Airy and durable.</div>
          <div class="item-feature"><span class="badge">✧ natural fiber</span><span class="badge">🌱 sustainably harvested</span></div>
        </div>
      </div>
      
      <!-- Item 9 : Sculptural Stool -->
      <div class="item-card">
        <div class="item-image" style="background: #E9DECE;">🗿 🪑</div>
        <div class="item-info">
          <h3>Pebble Stool / Side Table</h3>
          <div class="item-material">carved oak + oiled finish</div>
          <div class="item-description">Multipurpose organic shape, like a river stone.</div>
          <div class="item-feature"><span class="badge">✧ 2-in-1</span><span class="badge">🎨 handmade</span></div>
        </div>
      </div>
      
      <!-- Item 10 : Glass-front Cabinet -->
      <div class="item-card">
        <div class="item-image" style="background: #DECFBA;">🚪 ✨</div>
        <div class="item-info">
          <h3>Heritage Curio Cabinet</h3>
          <div class="item-material">cherry wood + glass panels</div>
          <div class="item-description">Display collectibles, adjustable interior lighting ready.</div>
          <div class="item-feature"><span class="badge">✧ brass hardware</span><span class="badge">🔒 soft-close hinges</span></div>
        </div>
      </div>

      <!-- Item 11 : Platform Bed (low) -->
      <div class="item-card">
        <div class="item-image" style="background: #E5D8C6;">🛌 🌙</div>
        <div class="item-info">
          <h3>Zen Platform Bed</h3>
          <div class="item-material">walnut & bamboo slats</div>
          <div class="item-description">Low-profile, space-saving with integrated nightstand ledge.</div>
          <div class="item-feature"><span class="badge">✧ tool-free assembly</span><span class="badge">♻️ recycled packaging</span></div>
        </div>
      </div>

      <!-- Item 12 : Ladder Desk -->
      <div class="item-card">
        <div class="item-image" style="background: #E1D2BC;">✍️ 📖</div>
        <div class="item-info">
          <h3>Leaning Ladder Desk</h3>
          <div class="item-material">solid pine + iron accents</div>
          <div class="item-description">Wall-mounted, fold-down surface with storage shelf. ideal for small spaces.</div>
          <div class="item-feature"><span class="badge">✧ space-saving</span><span class="badge">🪵 rustic modern</span></div>
        </div>
      </div>
    </div>

    <!-- secondary category anchors -->
    <div id="living" style="scroll-margin-top: 30px;"></div>
    <div class="highlight-row" style="margin-top: 20px;">
      <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 1.8rem;">✨ Living room highlights</h3>
      <div class="highlight-grid">
        <div class="highlight-card">Cloud Lounge Chair<br><span style="font-size:0.7rem;">walnut + wool</span></div>
        <div class="highlight-card">Mesa Coffee Table<br><span style="font-size:0.7rem;">white oak</span></div>
        <div class="highlight-card">Archway Bookshelf<br><span style="font-size:0.7rem;">walnut/steel</span></div>
        <div class="highlight-card">Woven Rattan Bench<br><span style="font-size:0.7rem;">teak/rattan</span></div>
      </div>
    </div>

    <div id="dining" style="scroll-margin-top: 30px;"></div>
    <div class="highlight-row">
      <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 1.8rem;">🍽️ Dining & kitchen collection</h3>
      <div class="highlight-grid">
        <div class="highlight-card">Valley Elm Table<br><span style="font-size:0.7rem;">seats 8-10</span></div>
        <div class="highlight-card">Gather Round Table<br><span style="font-size:0.7rem;">expandable maple</span></div>
        <div class="highlight-card">Pebble Stool<br><span style="font-size:0.7rem;">carved oak</span></div>
        <div class="highlight-card">Heritage Curio Cabinet<br><span style="font-size:0.7rem;">cherry/glass</span></div>
      </div>
    </div>

    <div id="bedroom" style="scroll-margin-top: 30px;"></div>
    <div class="highlight-row">
      <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 1.8rem;">🛌 bedroom sanctuaries</h3>
      <div class="highlight-grid">
        <div class="highlight-card">Spindle Bed Frame<br><span style="font-size:0.7rem;">ash wood</span></div>
        <div class="highlight-card">Zen Platform Bed<br><span style="font-size:0.7rem;">walnut/bamboo</span></div>
        <div class="highlight-card">Woven Bench<br><span style="font-size:0.7rem;">rattan storage</span></div>
      </div>
    </div>

    <!-- CTA brochure request / contact (no price, just inquiries) -->
    <div id="contact" class="contact-section" style="scroll-margin-top: 30px;">
      <h3 style="font-size: 1.9rem; font-family: 'Cormorant Garamond', serif;">Request our printed brochure</h3>
      <p style="max-width: 550px; margin: 16px auto; color: #3E3529;">Receive a full material swatch kit, dimensions catalog, and artisan story. We deliver worldwide.</p>
      <button class="btn-inquire" id="brochureRequestBtn">📮 Request free catalogue →</button>
      <p class="mt-2" style="font-size: 0.7rem;">or visit our showroom by appointment — we’d love to welcome you.</p>
    </div>
  </div>

  <!-- FOOTER as brochure back panel -->
  <div class="footer-brochure">
    <div class="footer-flex">
      <div><strong style="font-size:1rem;">Vanessa Martinez</strong><br>Handcrafted furniture studio<br>est. 2013 · Portland, ME</div>
      <div>✉️ vanessamartinez@gmail.com<br>📞 +1 (800) 843-9265<br>📍 Antipolo City</div>
      <div>📖 Bespoke commissions<br>🌲 Carbon-neutral woodshop<br>📐 Heirloom guarantee</div>
    </div>
    <div class="text-center" style="margin-top: 36px; border-top: 1px solid #4F3F2F; padding-top: 24px;">
      © 2025 Vanessa Martinez — every piece tells a story. All designs original. Printed on recycled paper.
    </div>
  </div>
</div>

<script>
  // interactive "request brochure" with modal / toast (brochure style, no prices)
  const requestBtn = document.getElementById('brochureRequestBtn');
  if (requestBtn) {
    requestBtn.addEventListener('click', () => {
      // create a nice modal that simulates request
      const modalOverlay = document.createElement('div');
      modalOverlay.style.position = 'fixed';
      modalOverlay.style.top = '0';
      modalOverlay.style.left = '0';
      modalOverlay.style.width = '100%';
      modalOverlay.style.height = '100%';
      modalOverlay.style.backgroundColor = 'rgba(40, 30, 20, 0.8)';
      modalOverlay.style.backdropFilter = 'blur(5px)';
      modalOverlay.style.display = 'flex';
      modalOverlay.style.alignItems = 'center';
      modalOverlay.style.justifyContent = 'center';
      modalOverlay.style.zIndex = '10000';
      modalOverlay.style.fontFamily = "'Inter', sans-serif";

      const modalCard = document.createElement('div');
      modalCard.style.background = '#FFFCF5';
      modalCard.style.maxWidth = '420px';
      modalCard.style.width = '85%';
      modalCard.style.borderRadius = '36px';
      modalCard.style.padding = '32px 28px';
      modalCard.style.boxShadow = '0 30px 40px rgba(0,0,0,0.3)';
      modalCard.style.textAlign = 'center';
      modalCard.innerHTML = `
        <span style="font-size: 2.8rem;">📖🍃</span>
        <h3 style="font-family: 'Cormorant Garamond', serif; font-size: 1.9rem; margin: 12px 0 4px;">Free brochure & sample</h3>
        <p style="margin: 12px 0 16px; color: #4b3b2a;">Enter your details to receive our full collection lookbook + wood swatches.</p>
        <input type="text" id="modalName" placeholder="Your name" style="width:100%; padding: 12px; border-radius: 60px; border:1px solid #E1D3C2; margin-bottom: 12px; background: white;">
        <input type="email" id="modalEmail" placeholder="Email address" style="width:100%; padding: 12px; border-radius: 60px; border:1px solid #E1D3C2; margin-bottom: 20px;">
        <button id="sendRequestBtn" style="background: #7C5F42; color:white; border:none; padding: 12px 0; width:100%; border-radius: 60px; font-weight:600; cursor:pointer;">Send me the brochure →</button>
        <button id="closeModalBtn" style="background:transparent; border:none; margin-top: 18px; font-size:0.75rem; cursor:pointer; color:#927C60;">Close</button>
      `;
      modalOverlay.appendChild(modalCard);
      document.body.appendChild(modalOverlay);

      const closeModal = () => modalOverlay.remove();
      document.getElementById('closeModalBtn')?.addEventListener('click', closeModal);
      document.getElementById('sendRequestBtn')?.addEventListener('click', () => {
        const nameInput = document.getElementById('modalName');
        const emailInput = document.getElementById('modalEmail');
        const name = nameInput?.value.trim() || 'friend';
        const email = emailInput?.value.trim();
        if (email && email.includes('@') && email.includes('.')) {
          alert(`✨ Thank you ${name}! Your Vanessa Martinez brochure will be sent to ${email} within 2 days. We plant a tree for every request. 🌳`);
          closeModal();
        } else {
          alert('🌿 Please provide a valid email so we can send the beautiful furniture catalogue.');
        }
      });
      modalOverlay.addEventListener('click', (e) => { if (e.target === modalOverlay) closeModal(); });
    });
  }

  // smooth scroll for anchor links
  document.querySelectorAll('.nav-brochure a').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
      const href = this.getAttribute('href');
      if (href && href !== '#') {
        const target = document.querySelector(href);
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    });
  });

  // small hover effect for cards
  const cards = document.querySelectorAll('.item-card');
  cards.forEach(card => {
    card.addEventListener('mouseenter', () => {
      card.style.transition = 'all 0.2s';
    });
  });

  // also console welcome
  console.log('Vanessa Martinez brochure — complete collection displayed, no prices, all items visible.');
</script>
</body>
</html>
