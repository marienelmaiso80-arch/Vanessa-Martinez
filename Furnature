        </div>
      </div>
      
      <!-- Item 2 : Cloud Lounge Chair -->
      <div class="item-card">
        <div class="item-image" style="background: #EBDDCB;">🪑 ☁️</div>
        <div class="item-info">
          <h3>Cloud Lounge Chair</h3>
          <div class="item-material">walnut frame + wool upholstery</div>
          <div class="item-description">Deep seat, ergonomic curve, hand-tufted back. Modern yet enveloping.</div>
          <div class="item-feature"><span class="badge">✧ certified wool</span><span class="badge">♻️ FSC wood</span></div>
        </div>
