<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Vanessa Martinez | Timeless Furniture Brochure</title>
  <!-- Google Fonts + subtle reset -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: #F6F2EA;  /* warm paper background */
      font-family: 'Inter', sans-serif;
      color: #2C2B28;
      scroll-behavior: smooth;
    }

    /* brochure wrapper */
    .brochure-container {
      max-width: 1400px;
      margin: 40px auto;
      background: #FEFCF8;
      box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.2);
      border-radius: 28px;
      overflow: hidden;
    }

    /* HEADER / COVER SECTION (like a brochure cover) */
    .cover {
      background: #F2ECE2;
      padding: 60px 48px 48px 48px;
      text-align: center;
      border-bottom: 2px solid #E0D6C8;
    }

    .brand {
      font-family: 'Cormorant Garamond', serif;
      font-size: 4rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      color: #4A3B2C;
      margin-bottom: 12px;
    }

    .tagline {
      font-size: 1rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #977B5C;
      border-top: 1px solid #DFD3C3;
      display: inline-block;
      padding-top: 12px;
    }

    .cover-desc {
      max-width: 600px;
      margin: 28px auto 0;
      color: #5E4F3C;
      line-height: 1.5;
      font-weight: 400;
    }

    /* navigation (minimal, like brochure tabs) */
    .nav-brochure {
      background: #FFFCF7;
      padding: 16px 32px;
      display: flex;
      justify-content: center;
      gap: 36px;
      border-bottom: 1px solid #E9E0D4;
      flex-wrap: wrap;
    }

    .nav-brochure a {
      text-decoration: none;
      font-weight: 500;
      color: #5A4A36;
      font-size: 0.9rem;
      transition: 0.2s;
      letter-spacing: 0.3px;
      border-bottom: 2px solid transparent;
      padding-bottom: 6px;
    }

    .nav-brochure a:hover {
      border-bottom-color: #B7976E;
      color: #2F241B;
    }

    /* section titles */
    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.6rem;
      font-weight: 500;
      color: #3A2C1F;
      margin-bottom: 16px;
      letter-spacing: -0.2px;
    }

    .section-sub {
      color: #807560;
      font-size: 1rem;
      margin-bottom: 40px;
      border-left: 3px solid #DBC9B2;
      padding-left: 18px;
      font-style: italic;
    }

    /* main content */
    .content-padding {
      padding: 48px 44px;
    }

    /* furniture grid (brochure style: all items visible, clean cards) */
    .furniture-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
      gap: 36px 28px;
      margin: 32px 0 20px;
    }

    .item-card {
      background: #FFFFFF;
      border-radius: 20px;
      overflow: hidden;
      transition: all 0.25s ease;
      box-shadow: 0 6px 14px rgba(0, 0, 0, 0.02);
      border: 1px solid #F0E6DA;
    }

    .item-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 20px 30px -12px rgba(60, 40, 20, 0.12);
      border-color: #E1D0BC;
    }

    .item-image {
      background-color: #EADFCB;
      height: 240px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 4rem;
      background-size: cover;
      background-position: center;
      transition: all 0.2s;
      color: #5E4A32;
    }

    /* different placeholder images with emoji + pattern (to represent each piece) */
    .item-info {
      padding: 22px 20px 24px;
    }

    .item-info h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.65rem;
      font-weight: 600;
      color: #3E2D1E;
      margin-bottom: 8px;
    }

    .item-material {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #AF9276;
      margin-bottom: 10px;
    }

    .item-description {
      font-size: 0.85rem;
      line-height: 1.45;
      color: #5C5348;
      margin-bottom: 18px;
    }

    .item-feature {
      display: flex;
      gap: 12px;
      font-size: 0.7rem;
      color: #7D6B56;
      border-top: 1px solid #F1E9DF;
      padding-top: 14px;
      margin-top: 6px;
    }

    .badge {
      background: #F8F2EA;
      padding: 4px 11px;
      border-radius: 40px;
      font-weight: 500;
    }

    /* special collections row */
    .highlight-row {
      background: #F9F5EE;
      border-radius: 32px;
      padding: 28px 32px;
      margin: 48px 0 24px;
      text-align: center;
    }

    .highlight-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 24px;
      justify-content: center;
      margin-top: 24px;
    }

    .highlight-card {
      background: white;
      border-radius: 24px;
      padding: 16px 20px;
      flex: 1 1 200px;
      box-shadow: 0 5px 12px rgba(0,0,0,0.03);
      border: 1px solid #E8DCCE;
    }

    /* CTA / contact */
    .contact-section {
      background: #E7DFD1;
      margin: 30px 0 20px;
      border-radius: 32px;
      padding: 44px 40px;
      text-align: center;
    }

    .btn-inquire {
      background: #7C5F42;
      color: white;
      border: none;
      padding: 14px 38px;
      border-radius: 60px;
      font-weight: 600;
      font-size: 0.9rem;
      cursor: pointer;
      transition: 0.2s;
      font-family: 'Inter', sans-serif;
      box-shadow: 0 3px 8px rgba(0,0,0,0.1);
      margin-top: 20px;
    }

    .btn-inquire:hover {
      background: #5C4632;
      transform: scale(0.97);
    }

    /* footer like brochure back cover */
    .footer-brochure {
      background: #2C241C;
      color: #D9CDBC;
      padding: 38px 44px 28px;
      font-size: 0.8rem;
      border-top: 1px solid #4C3D2E;
    }

    .footer-flex {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 30px;
    }

    /* responsive */
    @media (max-width: 780px) {
      .content-padding {
        padding: 32px 20px;
      }
      .cover {
        padding: 40px 24px;
      }
      .brand {
        font-size: 2.8rem;
      }
      .section-title {
        font-size: 2rem;
      }
      .nav-brochure {
        gap: 20px;
      }
    }

    /* utility */
    .text-center { text-align: center; }
    .mt-2 { margin-top: 12px; }
  </style>
</head>
<body>
<div class="brochure-container">
  
  <!-- COVER: brochure style -->
  <div class="cover">
    <div class="brand">Vanessa Martinez</div>
    <div class="tagline">✦ handcrafted furniture | timeless expression ✦</div>
    <p class="cover-desc">Solid wood · heirloom quality · made for generations. Each piece is a marriage of modern silhouette and traditional joinery. Discover our complete collection below — a curated brochure of every design.</p>
  </div>

  <!-- navigation anchor -->
  <div class="nav-brochure">
    <a href="#allpieces">All pieces</a>
    <a href="#living">Living room</a>
    <a href="#dining">Dining & kitchen</a>
    <a href="#bedroom">Bedroom</a>
    <a href="#contact">Request catalogue</a>
  </div>

  <!-- MAIN CONTENT: all furniture items shown (brochure style) -->
  <div class="content-padding" id="allpieces">
    <h2 class="section-title">The complete collection</h2>
    <div class="section-sub">Every piece, from sculptural chairs to expansive tables, crafted with natural oil finishes and premium hardwoods.</div>
    
    <!-- ---- ALL FURNITURE ITEMS (brochure grid, no prices, focused on materials & story) ---- -->
    <div class="furniture-grid">
      
      <!-- Item 1 : Elm Dining Table -->
      <div class="item-card">
